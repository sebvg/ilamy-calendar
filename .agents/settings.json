{
	"permissions": {
		"allow": [
			"WebFetch(domain:docs.anthropic.com)",
			"Bash(bun test:*)",
			"Bash(node:*)",
			"Bash(bun run:*)",
			"Bash(grep:*)",
			"WebSearch",
			"WebFetch(domain:fullcalendar.io)",
			"Bash(mkdir:*)",
			"Bash(rm:*)",
			"Bash(bunx tsc:*)",
			"WebFetch(domain:github.com)",
			"Bash(mv:*)",
			"Bash(true)",
			"Bash(cp:*)",
			"Bash(bunx esbuild-visualizer:*)",
			"Bash(cat:*)"
		],
		"deny": [],
		"ask": ["Bash(git commit *)"],
		"defaultMode": "acceptEdits"
	},
	"hooks": {
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/check-dev-log.sh"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/tdd-reminder.sh"
					}
				]
			}
		]
	}
}
